{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "api.main:app", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "streamlit",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "streamlit", "run", "app/streamlit_app.py",
                      "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    },
    {
      "name": "report",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "report/_site"],
      "port": 8080
    }
  ]
}
